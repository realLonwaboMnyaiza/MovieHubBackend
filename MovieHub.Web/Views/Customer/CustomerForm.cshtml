@model MovieHub.Web.ViewModels.Customer;
@{
    ViewBag.Title = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Create New Customer</h2>

@using (Html.BeginForm("SubmitCustomerForm", Customers))
{
    @Html.HiddenFor(m = m.Id)
    <div class="form-group">
        @Html.LabelFor(m => m.Name)
        @Html.TextBoxFor(m => m.Name, new { @class = "form-control"})
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.Birthdate)
        @Html.TextBoxFor(m => m.Birthdate, "{0:d MMM yyyy}" new { @class = "form-control"})
    </div>
     <div class="form-group">
        @Html.LabelFor(m => m.Customer.MembershipTypeId)
        @Html.DropDownListFor(m => m.Customer.MembershipTypeId, new SelectedList(Model.MembershipTypes, "Id", "Name"), "Select Membership Type",  new { @class = "form-control"})
    </div>
    <div class="checkbox">
        <label>
            @Html.CheckBoxFor(m => m.IsSubscribed) Subscribed to newsletter?
        </label>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
}