@model IList<MovieHub.ViewModels.Customer>

<div class="text-center">
    <h1 class="display-5">Customers</h1>
    @if (Model.Count() < 1)
    {
        <p>We don't have any customers yet.</p>
    }
    else
    {
        <ul>
            @foreach (var customer in Model)
            {
                <li>@customer.Name</li>
            }
        </ul>
    }
</div>
