@model IList<MovieHub.ViewModels.Movie>

<div class="text-center">
    <h1 class="display-5">Movies</h1>
    @if (Model.Count() == 0)
    {
        <p>We don't have any customers yet.</p>
    }
    else
    {
        <table>
            @foreach (var movie in Model)
            {
                <tr>
                    <td>@movie.Name</td>
                </tr>
            }
        </table>
    }
</div>
